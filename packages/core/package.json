{
  "name": "@kumix/core",
  "version": "0.0.0",
  "private": true,
  "description": "Core package for the Kumix template.",
  "license": "MIT",
  "author": "Kumix Labs <hai@kumix.io>",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "clean:all": "rimraf dist node_modules",
    "types:check": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
