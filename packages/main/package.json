{
  "name": "@kumix/main",
  "version": "0.0.0",
  "private": true,
  "description": "Main package for the Kumix template.",
  "author": "Kumix Labs <hai@kumix.io>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "tsc -b --clean && rimraf dist",
    "clean:all": "rimraf .turbo dist node_modules",
    "build": "tsc",
    "types:check": "tsc --noEmit -p tsconfig.json"
  },
  "homepage": "https://github.com/kumixlabs/template",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kumixlabs/template.git",
    "directory": "packages/main"
  },
  "bugs": {
    "url": "https://github.com/kumixlabs/template/issues"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "kumix",
    "template"
  ],
  "dependencies": {
    "@kumix/core": "workspace:*"
  },
  "devDependencies": {
    "@kumix/tsconfig": "^0.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
